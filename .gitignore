# Rust
/target
**/*.rs.bk

# mkdocs build output
/site/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
ENV/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# uv / maturin
.uv-cache/
*.so
*.pyd
*.dylib

# UniFFI smoke-test artifacts
crates/uniffi/smoke-test/generated/
crates/uniffi/smoke-test/smoke

# Editors / OS
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# WSL/NTFS "mark of the web" alternate-data-stream artifacts
*:Zone.Identifier

# Local scratch — manual-testing recordings / projects, informal artifacts
/ManualTesting/
/scratch/

# Reference assets — local-only copies of cited papers/specs (see refs/README.md).
# Not distributed: most are copyright and can't be redistributed. The
# authoritative reference is always the DOI/weblink in the code + citations;
# these PDFs are a local convenience only. The README is tracked; contents aren't.
/refs/*
!/refs/README.md

# Claude Code — personal workflow config (commands, settings), not project
# spec. Kept out of the repo so it isn't imposed on contributors.
/.claude/
# AI-assistant skill config (e.g. `hf skills add`) — personal, same rationale.
/.agents/
